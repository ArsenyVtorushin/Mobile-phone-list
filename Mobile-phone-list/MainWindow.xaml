<Window x:Class="Mobile_phone_list.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Mobile_phone_list"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="mainListBox" Grid.Column="0" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Path=Title}" 
                                   FontWeight="Bold" 
                                   FontSize="14"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Path=Company}" 
                                   FontSize="12"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Path=Price}" 
                                   FontSize="12"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Выбранный элемент" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Text="Модель:" Margin="0,5"/>
            <TextBox Name="titleView" Margin="0,2"/>

            <TextBlock Text="Производитель:" Margin="0,10,0,5"/>
            <TextBox Name="companyView" Margin="0,2"/>

            <TextBlock Text="Цена:" Margin="0,10,0,5"/>
            <TextBox Name="priceView" Margin="0,2"/>
        </StackPanel>

        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Bottom" 
                    Margin="10">
            <Button Content="+" Width="30" Height="30" Margin="0,0,5,0" Click="AddButton_Click"/>
            <Button Content="-" Width="30" Height="30" Click="RemoveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
