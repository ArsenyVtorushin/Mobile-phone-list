<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>Mobile_phone_list</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="img\edit.png" />
    <None Remove="img\plus.png" />
    <None Remove="img\trash.png" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="img\edit.png" />
    <Resource Include="img\plus.png" />
    <Resource Include="img\trash.png" />
  </ItemGroup>

</Project>
